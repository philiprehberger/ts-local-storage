{
  "name": "@philiprehberger/local-storage",
  "version": "0.1.2",
  "description": "Type-safe localStorage wrapper with JSON serialization, TTL, and key prefixing",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "localstorage",
    "storage",
    "session",
    "typed",
    "cache",
    "persist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-local-storage.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-local-storage#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-local-storage/issues"
  },
  "author": "Philip Rehberger",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
